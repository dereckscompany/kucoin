\subsection{Method \code{get_withdrawal_by_id()}}{
Get Withdrawal by ID

Retrieves comprehensive details for a specific withdrawal, including
chain information, failure reasons, cancel status, and return details.
Provides more information than the history endpoint.
\subsection{Workflow}{
\enumerate{
\item \strong{Request}: Authenticated GET to the withdrawal-specific endpoint.
\item \strong{Response}: KuCoin returns detailed withdrawal information.
\item \strong{Parsing}: Returns \code{data.table} with full withdrawal details.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/withdrawals/\{withdrawalId\}}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/account-info/withdrawals/get-withdrawal-by-id}{KuCoin Get Withdrawal Detail}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Status Tracking}: Monitor withdrawal progress through \code{REVIEW} → \code{PROCESSING} → \code{WALLET_PROCESSING} → \code{SUCCESS}.
\item \strong{Failure Diagnosis}: Check \code{failure_reason} and \code{failure_reason_msg} to understand why a withdrawal failed.
\item \strong{Cancel Eligibility}: Use \code{cancel_type} (\code{"CANCELABLE"}, \code{"CANCELING"}, \code{"NON_CANCELABLE"}) to determine if a withdrawal can still be cancelled.
}
}

