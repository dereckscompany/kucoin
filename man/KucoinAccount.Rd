\subsection{Method \code{get_fee_rate()}}{
Get Actual Fee Rate

Retrieves the actual (per-symbol) taker and maker fee rates after
VIP/KCS discounts. Supports up to 10 trading pairs per request.
\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/trade-fees}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/account-info/trade-fee/get-actual-fee-spot-margin}{KuCoin Get Actual Fee}

Verified: 2026-05-23
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/trade-fees?symbols=BTC-USDT,ETH-USDT' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": [
    \{
      "symbol": "BTC-USDT",
      "takerFeeRate": "0.001",
      "makerFeeRate": "0.001"
    \},
    \{
      "symbol": "ETH-USDT",
      "takerFeeRate": "0.001",
      "makerFeeRate": "0.001"
    \}
  ]
\}
}\if{html}{\out{</div>}}
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Precise PnL}: Use actual rates for accurate profit/loss calculations.
\item \strong{Fee Optimization}: Compare rates across pairs to choose the cheapest execution venue.
\item \strong{Batch Query}: Query up to 10 pairs at once to minimize API calls.
}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinAccount$get_fee_rate(symbols)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbols}}{Character; comma-separated trading pairs (max 10),
e.g. \code{"BTC-USDT,ETH-USDT"}.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
\code{data.table} (or \verb{promise<data.table>} if constructed with \code{async = TRUE}) with columns:
\itemize{
\item \code{symbol} (character): Trading pair.
\item \code{taker_fee_rate} (character): Actual taker fee rate.
\item \code{maker_fee_rate} (character): Actual maker fee rate.
}
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
account <- KucoinAccount$new()
fees <- account$get_fee_rate("BTC-USDT,ETH-USDT")
print(fees[, .(symbol, taker_fee_rate, maker_fee_rate)])
}
}
\if{html}{\out{</div>}}

}

}
