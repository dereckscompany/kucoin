\subsection{Method \code{get_server_time()}}{
Get Server Time

Retrieves the KuCoin Futures server timestamp. Useful for synchronising
local clocks and debugging timestamp-related authentication issues.
\subsection{Workflow}{
\enumerate{
\item \strong{Request}: Public GET to the timestamp endpoint.
\item \strong{Parsing}: Wraps the scalar millisecond timestamp into a single-row \code{data.table} with POSIXct conversion.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/timestamp}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/futures-trading/market-data/get-server-time}{KuCoin Get Server Time}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Clock Synchronisation}: Compare server time with local time to detect and compensate for clock drift.
\item \strong{Auth Debugging}: Verify that your timestamp is within the acceptable window for HMAC signature generation.
\item \strong{Latency Measurement}: Calculate round-trip latency by comparing request send time to server time.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/timestamp'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": 1698267054123
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinFuturesMarketData$get_server_time()}\if{html}{\out{</div>}}
}

\subsection{Returns}{
(data.table | promise<data.table>) one row giving the server
datetime (POSIXct, coerced from epoch milliseconds):
\itemize{
\item server_time (POSIXct) the server time (UTC).
}
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
futures_market <- KucoinFuturesMarketData$new()
server_time <- futures_market$get_server_time()
print(server_time$server_time)
}
}
\if{html}{\out{</div>}}

}

}
