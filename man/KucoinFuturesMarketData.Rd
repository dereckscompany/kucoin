\subsection{Method \code{get_klines()}}{
Get Klines (Candlestick Data)

Retrieves historical kline/candlestick data for a futures contract.
Supports both single-call mode and automatic multi-segment fetching
for large time ranges.
\subsection{Workflow}{
\enumerate{
\item \strong{fetch_all Mode} (when \code{fetch_all = TRUE}): Segments the time range into chunks of up to 200 candles,
fetches each segment via \code{kucoin_fetch_futures_klines()}, deduplicates overlapping boundaries, and
returns the combined result sorted by \code{datetime}.
\item \strong{Single-Call Mode} (default): Sends a single GET request with \code{from}/\code{to} query parameters.
\item \strong{Parsing}: Converts the nested array response into a \code{data.table} via \code{parse_futures_klines()}.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/kline/query?symbol=\{symbol\}&granularity=\{granularity\}&from=\{from\}&to=\{to\}}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/futures-trading/market-data/get-klines}{KuCoin Get Klines}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Technical Analysis}: Feed OHLCV data into indicator calculations (RSI, MACD, Bollinger Bands, etc.).
\item \strong{Backtesting}: Use \code{fetch_all = TRUE} to download complete historical datasets for strategy backtesting.
\item \strong{Real-Time Charting}: Poll the latest candle at regular intervals to update live charts.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/kline/query?symbol=XBTUSDTM&granularity=60&from=1698220800000&to=1698307200000'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": [
    [1698220800000, 68100.0, 68250.5, 68050.2, 68200.1, 15234.0, 1037945.82],
    [1698224400000, 68200.1, 68400.0, 68150.3, 68350.7, 12876.0, 879654.31],
    [1698228000000, 68350.7, 68500.2, 68300.0, 68125.3, 18492.0, 1263571.45]
  ]
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinFuturesMarketData$get_klines(
  symbol,
  granularity,
  from = NULL,
  to = NULL,
  fetch_all = FALSE,
  sleep = 0.2
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol}}{(scalar<character>) futures symbol (e.g., \code{"XBTUSDTM"}).}

\item{\code{granularity}}{(scalar<count in [1, Inf[>) candle interval in minutes.
Supported values: 1, 5, 15, 30, 60, 120, 240, 480, 720, 1440, 10080.}

\item{\code{from}}{(POSIXct | scalar<numeric> | NULL) start time. If POSIXct,
converted to milliseconds. If numeric, assumed to be milliseconds.}

\item{\code{to}}{(POSIXct | scalar<numeric> | NULL) end time.}

\item{\code{fetch_all}}{(scalar<logical>) if \code{TRUE}, automatically segments the
time range into multiple API calls of up to 200 candles each, fetches all
segments, deduplicates overlapping boundaries, and returns the combined
result sorted by \code{datetime}. Both \code{from} and \code{to} are required when
enabled. \strong{Warning}: large date ranges will consume multiple API requests
and may impact your rate-limit quota. Default \code{FALSE}.}

\item{\code{sleep}}{(scalar<numeric in [0, Inf[>) seconds to wait between
consecutive API calls when \code{fetch_all = TRUE}. Use this to avoid hitting
KuCoin rate limits. Only applies in synchronous mode; async mode chains
requests sequentially via promises. Default \code{0.2}.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Klines | promise<Klines>) one row per candle ascending by datetime.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
futures_market <- KucoinFuturesMarketData$new()

# Single call: last 200 hourly candles
klines <- futures_market$get_klines(
  "XBTUSDTM",
  granularity = 60,
  from = as.numeric(Sys.time() - 200 * 3600) * 1000,
  to = as.numeric(Sys.time()) * 1000
)
print(klines[, .(datetime, open, high, low, close, volume)])

# Fetch all: complete hourly history for a date range
all_klines <- futures_market$get_klines(
  "XBTUSDTM",
  granularity = 60,
  from = as.POSIXct("2024-10-01", tz = "UTC"),
  to = as.POSIXct("2024-10-31", tz = "UTC"),
  fetch_all = TRUE,
  sleep = 0.3
)
print(nrow(all_klines))
}
}
\if{html}{\out{</div>}}

}

}
