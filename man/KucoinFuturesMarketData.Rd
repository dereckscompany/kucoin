\if{latex}{\out{\hypertarget{method-KucoinFuturesMarketData-get_service_status}{}}}
\subsection{Method \code{get_service_status()}}{
Get Service Status

Retrieves the current service status of the KuCoin Futures exchange.
Check this before placing orders to confirm the exchange is operational.
\subsection{Workflow}{
\enumerate{
\item \strong{Request}: Public GET to the status endpoint.
\item \strong{Parsing}: Returns a single-row \code{data.table} with the service status and message.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/status}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/futures-trading/market-data/get-service-status}{KuCoin Get Service Status}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Health Check}: Poll service status at bot startup and periodically during operation to detect maintenance
windows.
\item \strong{Graceful Degradation}: When status is \code{"close"}, pause order placement and alert the operator.
\item \strong{Maintenance Scheduling}: Use the \code{msg} field to extract maintenance window details for automated scheduling.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/status'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "status": "open",
    "msg": ""
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinFuturesMarketData$get_service_status()}\if{html}{\out{</div>}}
}

\subsection{Returns}{
(data.table | promise<data.table>) one row giving the operational
status (\code{"open"}, \code{"close"}, or \code{"cancelonly"}) and an optional
remark/message:
\itemize{
\item status (character) the status.
\item msg (character) the msg.
}
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
futures_market <- KucoinFuturesMarketData$new()
status <- futures_market$get_service_status()
if (status$status == "open") message("Exchange is operational")
}
}
\if{html}{\out{</div>}}

}

}
