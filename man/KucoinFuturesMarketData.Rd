\if{latex}{\out{\hypertarget{method-KucoinFuturesMarketData-get_funding_history}{}}}
\subsection{Method \code{get_funding_history()}}{
Get Public Funding Rate History

Retrieves historical funding rates for a futures contract over a
specified time range.
\subsection{Workflow}{
\enumerate{
\item \strong{Time Conversion}: Converts POSIXct \code{from}/\code{to} to milliseconds if needed.
\item \strong{Request}: Public GET with \code{symbol}, \code{from}, and \code{to} query parameters.
\item \strong{Parsing}: Returns a \code{data.table} with one row per funding settlement; coerces \code{timepoint} from milliseconds
to POSIXct.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/contract/funding-rates?symbol=\{symbol\}&from=\{from\}&to=\{to\}}
}

\subsection{Official Documentation}{

KuCoin Get Public Funding Rate History:
\url{https://www.kucoin.com/docs-new/rest/futures-trading/funding-fees/get-public-funding-history}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Funding Rate Analysis}: Analyse historical funding rates to understand market sentiment (positive = longs
pay shorts).
\item \strong{Mean Reversion Signals}: Extreme funding rates often precede reversals; use historical data to calibrate
thresholds.
\item \strong{Carry Trade Evaluation}: Calculate cumulative funding paid/received over a time period for carry trade
analysis.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/contract/funding-rates?symbol=XBTUSDTM&from=1698220800000&to=1698307200000'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": [
    \{
      "symbol": "XBTUSDTM",
      "fundingRate": 0.000065,
      "timepoint": 1698220800000
    \},
    \{
      "symbol": "XBTUSDTM",
      "fundingRate": 0.000042,
      "timepoint": 1698249600000
    \},
    \{
      "symbol": "XBTUSDTM",
      "fundingRate": 0.000035,
      "timepoint": 1698278400000
    \}
  ]
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinFuturesMarketData$get_funding_history(symbol, from, to)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol}}{(scalar<character>) futures symbol (e.g., \code{"XBTUSDTM"}).}

\item{\code{from}}{(POSIXct | scalar<numeric>) start time. If POSIXct, converted to
milliseconds. If numeric, assumed to be milliseconds.}

\item{\code{to}}{(POSIXct | scalar<numeric>) end time. If POSIXct, converted to
milliseconds. If numeric, assumed to be milliseconds.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row per funding settlement,
each giving the contract symbol, the funding rate for the period, and the
settlement datetime (POSIXct, coerced from epoch milliseconds).
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
futures_market <- KucoinFuturesMarketData$new()
history <- futures_market$get_funding_history(
  symbol = "XBTUSDTM",
  from = as.POSIXct("2024-10-25", tz = "UTC"),
  to = as.POSIXct("2024-10-26", tz = "UTC")
)
print(history[, .(symbol, funding_rate, timepoint)])
}
}
\if{html}{\out{</div>}}

}

}
