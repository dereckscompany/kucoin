\subsection{Method \code{get_klines()}}{
Get Klines (Candlestick Data)

Retrieves historical OHLCV candlestick data for a symbol. Automatically
segments requests to handle KuCoin's 1500-candle-per-request limit,
fetching and combining as many segments as needed to cover the requested
time range.
\subsection{Workflow}{
\enumerate{
\item \strong{Validation}: Validates timeframe string against allowed intervals.
\item \strong{Segmentation}: Splits the \verb{[from, to]} range into chunks of up to 1500 candles.
\item \strong{Fetching}: Requests each segment sequentially (sync) or in parallel (async).
\item \strong{Parsing}: Each segment's array-of-arrays response is converted to a typed \code{data.table}.
\item \strong{Deduplication}: Removes duplicate candles at segment boundaries.
\item \strong{Sorting}: Returns rows ordered by \code{datetime} ascending.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/market/candles}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/market-data/get-klines}{KuCoin Get Klines}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Backtesting}: Fetch large historical ranges for strategy backtesting.
\item \strong{Technical Indicators}: Feed OHLCV data into indicator calculations (SMA, RSI, MACD).
\item \strong{Real-Time Candles}: Poll with short \verb{[from, to]} windows for live candle updates.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/market/candles?symbol=BTC-USDT&type=1hour&startAt=1750389927&endAt=1750393527'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

Each candle is an array: \verb{[timestamp, open, close, high, low, volume, turnover]}

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": [
    ["1566789720", "10411.5", "10401.9", "10411.5", "10396.3", "29.11357276", "302889.301529914"],
    ["1566789660", "10416", "10411.5", "10422.3", "10411.5", "15.61781842", "162703.708997029"]
  ]
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinMarketData$get_klines(
  symbol,
  timeframe = "15min",
  from = NULL,
  to = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol}}{(scalar<character>) trading pair (e.g., \code{"BTC-USDT"}).}

\item{\code{timeframe}}{(scalar<character>) candle interval. One of:
\code{"1min"}, \code{"3min"}, \code{"5min"}, \code{"15min"}, \code{"30min"},
\code{"1hour"}, \code{"2hour"}, \code{"4hour"}, \code{"6hour"}, \code{"8hour"}, \code{"12hour"},
\code{"1day"}, \code{"1week"}, \code{"1month"}. Default \code{"15min"}.}

\item{\code{from}}{(POSIXct | scalar<numeric> | NULL) start time. When both \code{from}
and \code{to} are \code{NULL}, the API returns up to 1500 most recent candles.}

\item{\code{to}}{(POSIXct | scalar<numeric> | NULL) end time.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Klines | promise<Klines>) one row per candle ascending by datetime.
}
