\subsection{Method \code{get_fiat_prices()}}{
Get Fiat Prices

Retrieves current fiat-equivalent prices for cryptocurrencies.
Useful for portfolio valuation and P&L reporting in fiat terms.
\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v1/prices}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/market-data/get-fiat-price}{KuCoin Get Fiat Price}

Verified: 2026-05-23
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v1/prices?base=USD&currencies=BTC,ETH,USDT'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "BTC": "67269.15",
    "ETH": "2485.73",
    "USDT": "1.0002"
  \}
\}
}\if{html}{\out{</div>}}
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Portfolio Valuation}: Convert all holdings to USD/EUR for dashboard reporting.
\item \strong{Position Sizing}: Size positions in native fiat currency terms.
\item \strong{PnL Reporting}: Calculate profit/loss in fiat for accounting.
}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinMarketData$get_fiat_prices(base = NULL, currencies = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{base}}{(scalar<character> | NULL) fiat currency ticker (e.g.,
\code{"USD"}, \code{"EUR"}). Default \code{"USD"}.}

\item{\code{currencies}}{(scalar<character> | NULL) comma-separated crypto tickers
to convert (e.g., \code{"BTC,ETH,USDT"}). If NULL, returns all available.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row per cryptocurrency,
giving its ticker and fiat price as a string.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
market <- KucoinMarketData$new()
prices <- market$get_fiat_prices(base = "USD", currencies = "BTC,ETH,USDT")
print(prices)
}
}
\if{html}{\out{</div>}}

}

