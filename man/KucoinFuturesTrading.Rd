\subsection{\code{KucoinFuturesTrading$cancel_all()}}{
  Cancel All Orders

Cancels all open futures orders, optionally filtered by symbol. This is a
bulk operation that cancels limit and market orders (but not stop orders;
use \code{cancel_all_stop_orders()} for those).
\subsection{Workflow}{
\enumerate{
\item \strong{Request}: Authenticated DELETE with optional \code{symbol} query parameter.
\item \strong{Parsing}: Returns \code{data.table} with the list of all cancelled order IDs.
}
}

\subsection{API Endpoint}{

\verb{DELETE https://api-futures.kucoin.com/api/v1/orders}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/futures-trading/orders/cancel-all-orders}{KuCoin Cancel All Futures Orders}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Emergency Stop}: Cancel all open orders as part of a kill-switch or panic button.
\item \strong{Strategy Reset}: Clear all pending orders before deploying a new trading strategy.
\item \strong{Symbol-Scoped Cleanup}: Pass \code{symbol} to cancel only orders for a specific contract without affecting other positions.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request DELETE \\
  'https://api-futures.kucoin.com/api/v1/orders?symbol=XBTUSDTM' \\
