\subsection{Method \code{get_order_list()}}{
Get OCO Order List

Retrieves a paginated list of OCO orders with optional filtering by symbol,
time range, and pagination parameters. Returns all OCO orders matching the
specified criteria.
\subsection{Workflow}{
\enumerate{
\item \strong{Filter Construction}: Builds query parameters from the provided filter list.
\item \strong{Request}: Authenticated GET to the order list endpoint.
\item \strong{Pagination}: KuCoin returns a paginated response with \code{items} array.
\item \strong{Parsing}: Binds all items into a single \code{data.table} using \code{rbindlist()}.
}
}

\subsection{API Endpoint}{

\verb{GET https://api.kucoin.com/api/v3/oco/orders}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/get-oco-order-list}{KuCoin Get OCO Order List}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Portfolio Overview}: List all active OCO orders to display current take-profit/stop-loss levels across
positions.
\item \strong{Stale Order Detection}: Filter by \code{startAt}/\code{endAt} to find OCO orders that have been open too long and may
need adjustment.
\item \strong{Pagination Loop}: Use \code{currentPage} and \code{pageSize} to iterate through large result sets in batch processing.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request GET \\
  'https://api.kucoin.com/api/v3/oco/orders?symbol=BTC-USDT&pageSize=20&currentPage=1' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "currentPage": 1,
    "pageSize": 20,
    "totalNum": 2,
    "totalPage": 1,
    "items": [
      \{
        "orderId": "674c40d38b4b2f00073deef3",
        "symbol": "BTC-USDT",
        "clientOid": "my-bot-oco-001",
        "orderTime": 1729176273859,
        "status": "NEW"
      \},
      \{
        "orderId": "674c40d38b4b2f00073deef6",
        "symbol": "ETH-USDT",
        "clientOid": "my-bot-oco-002",
        "orderTime": 1729176274000,
        "status": "TRIGGERED"
      \}
    ]
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinOcoOrders$get_order_list(query = list())}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{query}}{(list) optional filter and pagination parameters. Supported
keys: \code{symbol} (trading pair to filter by e.g. \code{"BTC-USDT"}), \code{startAt}
(start time in milliseconds, inclusive), \code{endAt} (end time in
milliseconds, inclusive), \code{pageSize} (number of results per page, default
20, max 100), and \code{currentPage} (page number to retrieve, default 1).}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row per OCO order, each
giving the OCO order identifier, trading pair, client-assigned order
identifier, order creation datetime (POSIXct, coerced from epoch
milliseconds), and order status (e.g., \code{"NEW"}, \code{"DONE"}, \code{"TRIGGERED"});
an empty data.table if no orders match.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
oco <- KucoinOcoOrders$new()

# Get all OCO orders
orders <- oco$get_order_list()
print(orders)

# Filter by symbol with pagination
orders <- oco$get_order_list(query = list(
  symbol = "BTC-USDT",
  pageSize = 50,
  currentPage = 1
))
print(orders)

# Filter by time range
orders <- oco$get_order_list(query = list(
  startAt = as.numeric(lubridate::now() - 86400) * 1000,
  endAt = as.numeric(lubridate::now()) * 1000
))
}
}
\if{html}{\out{</div>}}

}

}
