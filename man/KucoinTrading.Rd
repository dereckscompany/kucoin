\subsection{Method \code{add_order()}}{
Place an Order

Places a new limit or market order on KuCoin Spot via the HF endpoint.
Parameters are validated by \code{validate_order_params()} before submission.
\subsection{Workflow}{
\enumerate{
\item \strong{Validation}: Calls \code{validate_order_params()} for type-specific checks.
\item \strong{Request}: Authenticated POST with order body.
\item \strong{Parsing}: Returns \code{data.table} with \code{order_id} and \code{client_oid}.
}
}

\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v1/hf/orders}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/add-order}{KuCoin Add Order}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Limit Orders}: Set \code{price} and \code{size} for precise entry/exit points.
\item \strong{Market Orders}: Use \code{size} for base-amount or \code{funds} for quote-amount execution.
\item \strong{Post-Only}: Set \code{postOnly = TRUE} to guarantee maker fees (order rejected if it would match).
\item \strong{Iceberg Orders}: Set \code{iceberg = TRUE} with \code{visibleSize} to hide large order quantities.
}
}

