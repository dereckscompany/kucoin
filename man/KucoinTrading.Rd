\subsection{Method \code{add_order_batch()}}{
Place Batch Orders

Places up to 20 orders in a single request. Each order is validated
independently. Failed orders return \code{success = FALSE} with a \code{fail_msg}.
\subsection{Workflow}{
\enumerate{
\item \strong{Validation}: Each order in the list is validated via \code{validate_batch_order()}.
\item \strong{Request}: Authenticated POST with \code{orderList} body.
\item \strong{Parsing}: Returns per-order results with success/failure status.
}
}

\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v1/hf/orders/multi}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/batch-add-orders}{KuCoin Batch Add Orders}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Portfolio Rebalancing}: Submit multiple orders across pairs simultaneously.
\item \strong{Grid Trading}: Place a grid of limit orders at different price levels.
\item \strong{Error Handling}: Check \code{success} column to identify and retry failed orders.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request POST 'https://api.kucoin.com/api/v1/hf/orders/multi' \\
  --header 'Content-Type: application/json' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2' \\
  --data-raw '\{"orderList":[\{"clientOid":"id1","symbol":"BTC-USDT","type":"limit","side":"buy","price":"30000","size":"0.00001"\}]\}'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "orderList": [
    \{
      "clientOid": "id1",
      "symbol": "BTC-USDT",
      "type": "limit",
      "side": "buy",
      "price": "30000",
      "size": "0.00001"
    \},
    \{
      "clientOid": "id2",
      "symbol": "ETH-USDT",
      "type": "limit",
      "side": "buy",
      "price": "2000",
      "size": "0.001"
    \}
  ]
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": [
    \{
      "orderId": "6710d8336afcdb0007319c27",
      "clientOid": "client order id 12",
      "success": true
    \},
    \{
      "success": false,
      "failMsg": "The order funds should more then 0.1 USDT."
    \}
  ]
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinTrading$add_order_batch(order_list)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{order_list}}{(list) list of named lists; each containing order parameters
(\code{type}, \code{symbol}, \code{side}, plus optional fields). Maximum 20 orders.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row per order giving the KuCoin order ID, client order ID, the
success flag, and any failure message.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
trading <- KucoinTrading$new()
orders <- trading$add_order_batch(list(
  list(type = "limit", symbol = "BTC-USDT", side = "buy",
       price = "30000", size = "0.00001", clientOid = "order1"),
  list(type = "limit", symbol = "ETH-USDT", side = "buy",
       price = "2000", size = "0.001", clientOid = "order2")
))
print(orders[success == TRUE, .(order_id, client_oid)])
print(orders[success == FALSE, .(fail_msg)])
}
}
\if{html}{\out{</div>}}

}

}
