    "originSize": "0.00001",
    "dealSize": "0",
    "remainSize": "0",
    "canceledSize": "0.00001",
    "status": "done"
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinTrading$cancel_order_by_id_sync(orderId, symbol)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
