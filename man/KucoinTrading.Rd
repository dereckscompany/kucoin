\subsection{Method \code{add_order_sync()}}{
Place an Order (Synchronous Return)

Places a new limit or market order and waits for the matching engine to
process it before returning. Returns the fill result in one round trip,
eliminating the need to poll \code{get_order_by_id()}.
\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v1/hf/orders/sync}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/add-order-sync}{KuCoin Add Order Sync}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Low-Latency Fills}: Get fill result in a single round trip instead of polling.
\item \strong{Market Orders}: Ideal for market orders where immediate fill confirmation is critical.
\item \strong{Race-Free}: No gap between order placement and status check.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request POST 'https://api.kucoin.com/api/v1/hf/orders/sync' \\
  --header 'Content-Type: application/json' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2' \\
  --data-raw '\{"type":"limit","symbol":"BTC-USDT","side":"buy","price":"50000","size":"0.00001"\}'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "type": "limit",
  "symbol": "BTC-USDT",
  "side": "buy",
  "price": "50000",
  "size": "0.00001",
  "clientOid": "5c52e11203aa677f33e493fb"
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "orderId": "670fd33bf9406e0007ab3945",
    "orderTime": 1729176273859,
    "originSize": "0.00001",
    "dealSize": "0.00001",
    "remainSize": "0",
    "canceledSize": "0",
    "status": "done",
    "matchTime": 1729176273952
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinTrading$add_order_sync(
  type,
  symbol,
  side,
  clientOid = NULL,
  price = NULL,
  size = NULL,
  funds = NULL,
  stp = NULL,
  tags = NULL,
  remark = NULL,
  timeInForce = NULL,
  cancelAfter = NULL,
  postOnly = NULL,
  hidden = NULL,
  iceberg = NULL,
  visibleSize = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{type}}{(scalar<character>) \code{"limit"} or \code{"market"}.}

\item{\code{symbol}}{(scalar<character>) trading pair (e.g., \code{"BTC-USDT"}).}

\item{\code{side}}{(scalar<character>) \code{"buy"} or \code{"sell"}.}

\item{\code{clientOid}}{(scalar<character> | NULL) unique client order ID (max 40 chars).}

\item{\code{price}}{(scalar<numeric> | scalar<character> | NULL) price for limit orders.}

\item{\code{size}}{(scalar<numeric> | scalar<character> | NULL) quantity in base currency.}

\item{\code{funds}}{(scalar<numeric> | scalar<character> | NULL) amount in quote currency for market orders.}

\item{\code{stp}}{(scalar<character> | NULL) self-trade prevention: \code{"CN"}, \code{"CO"}, \code{"CB"}, \code{"DC"}.}

\item{\code{tags}}{(scalar<character> | NULL) order tag (max 20 ASCII chars).}

\item{\code{remark}}{(scalar<character> | NULL) remarks (max 20 ASCII chars).}

\item{\code{timeInForce}}{(scalar<character> | NULL) \code{"GTC"}, \code{"GTT"}, \code{"IOC"}, \code{"FOK"}.}

\item{\code{cancelAfter}}{(scalar<numeric> | NULL) auto-cancel seconds (requires \code{timeInForce = "GTT"}).}

\item{\code{postOnly}}{(scalar<logical> | NULL) if TRUE, order rejected if it would match immediately.}

\item{\code{hidden}}{(scalar<logical> | NULL) if TRUE, order hidden from order book.}

\item{\code{iceberg}}{(scalar<logical> | NULL) if TRUE, only \code{visibleSize} is shown.}

\item{\code{visibleSize}}{(scalar<numeric> | scalar<character> | NULL) visible quantity for iceberg orders.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row giving the order and client identifiers, the order placement
datetime, the original, filled, remaining, and cancelled sizes, and the fill status.
}
