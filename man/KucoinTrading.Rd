\subsection{Method \code{set_dcp()}}{
Set DCP (Dead Connection Protection)

Configures KuCoin's dead-man's switch. If no user requests are received
within the timeout window, KuCoin automatically cancels all open HF orders
for the specified symbols (or all symbols if none specified).
\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v1/hf/orders/dead-cancel-all}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/set-dcp}{KuCoin Set DCP}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Crash Safety}: Heartbeat every N seconds; if bot crashes, KuCoin cancels all orders.
\item \strong{Network Failsafe}: Protects against network outages leaving stale orders.
\item \strong{Selective Protection}: Specify symbols to protect only active trading pairs.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request POST 'https://api.kucoin.com/api/v1/hf/orders/dead-cancel-all' \\
  --header 'Content-Type: application/json' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2' \\
  --data-raw '\{"timeout":30,"symbols":"BTC-USDT"\}'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "timeout": 30,
  "symbols": "BTC-USDT,ETH-USDT"
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "currentTime": 1729176273,
    "triggerTime": 1729176303
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinTrading$set_dcp(timeout, symbols = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{timeout}}{(scalar<numeric>) trigger duration in seconds. Use \code{-1} to disable, or \code{5} to \code{86400}.}

\item{\code{symbols}}{(scalar<character> | NULL) comma-separated trading pairs (max 50).
Empty or NULL applies to all pairs.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row giving the current server time and the time at which
cancellation will trigger, both in seconds.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
trading <- KucoinTrading$new()
# Enable DCP with 30-second timeout for BTC-USDT
result <- trading$set_dcp(timeout = 30, symbols = "BTC-USDT")
cat("Trigger at:", result$trigger_time, "\n")

# Disable DCP
trading$set_dcp(timeout = -1)
}
}
\if{html}{\out{</div>}}

}

}
