\subsection{Method \code{modify_order()}}{
Modify Order

Amends the price and/or size of an existing open order atomically.
Internally, KuCoin cancels the original order and places a replacement.
If the new size is less than the already filled quantity, the order is
simply cancelled with no replacement.
\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v1/hf/orders/alter}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/spot-trading/orders/modify-order}{KuCoin Modify Order}

Verified: 2026-05-23
}

\subsection{Automated Trading Usage}{
\itemize{
\item \strong{Price Adjustment}: Move a resting limit order to a new price level without cancel+replace gap.
\item \strong{Size Adjustment}: Increase or decrease order size atomically.
\item \strong{Trailing Logic}: Continuously adjust price as the market moves.
}
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request POST 'https://api.kucoin.com/api/v1/hf/orders/alter' \\
  --header 'Content-Type: application/json' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2' \\
  --data-raw '\{"symbol":"BTC-USDT","orderId":"671124f9365ccb00073debd4","newPrice":"51000"\}'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "symbol": "BTC-USDT",
  "orderId": "671124f9365ccb00073debd4",
  "newPrice": "51000",
  "newSize": "0.00002"
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "newOrderId": "671124f9365ccb00073debff"
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinTrading$modify_order(
  symbol,
  orderId = NULL,
  clientOid = NULL,
  newPrice = NULL,
  newSize = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol}}{(scalar<character>) trading pair (e.g., \code{"BTC-USDT"}). Required.}

\item{\code{orderId}}{(scalar<character> | NULL) KuCoin order ID. At least one of \code{orderId} or \code{clientOid} required.}

\item{\code{clientOid}}{(scalar<character> | NULL) client order ID. At least one of \code{orderId} or \code{clientOid} required.}

\item{\code{newPrice}}{(scalar<numeric> | scalar<character> | NULL) new order price. At least one of \code{newPrice} or
\code{newSize} required.}

\item{\code{newSize}}{(scalar<numeric> | scalar<character> | NULL) new order size. At least one of \code{newPrice} or
\code{newSize} required.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row giving the replacement order's ID and the original client
order ID.
}
