\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "currency": "USDT",
  "size": "100",
  "timeInForce": "IOC",
  "isIsolated": false,
  "isHf": false
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": \{
    "orderNo": "abc123",
    "actualSize": "100"
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinMarginTrading$borrow(
  currency,
  size,
  timeInForce = "IOC",
  isIsolated = FALSE,
  symbol = NULL,
  isHf = FALSE
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{currency}}{(scalar<character>) the currency to borrow (e.g.,
\code{"USDT"}, \code{"BTC"}).}

\item{\code{size}}{(scalar<numeric>) the amount to borrow.}

\item{\code{timeInForce}}{(scalar<character>) order time-in-force policy (default
\code{"IOC"}). Valid values: \code{"IOC"} (immediate-or-cancel), \code{"FOK"}
