  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinMarginTrading$close_long(
  symbol,
  size = NULL,
  funds = NULL,
  type = "market",
  price = NULL,
  isIsolated = FALSE,
  clientOid = NULL,
  stp = NULL,
  remark = NULL,
  timeInForce = NULL,
  cancelAfter = NULL,
  postOnly = NULL,
  hidden = NULL,
  iceberg = NULL,
  visibleSize = NULL,
  dry_run = FALSE
)}\if{html}{\out{</div>}}
}

