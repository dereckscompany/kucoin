\subsection{Method \code{modify_leverage()}}{
Modify Leverage

Updates the leverage multiplier for the margin account. Higher
leverage means you can borrow more relative to your collateral,
but also increases liquidation risk.
\subsection{API Endpoint}{

\verb{POST https://api.kucoin.com/api/v3/position/update-user-leverage}
}

\subsection{Official Documentation}{

\href{https://www.kucoin.com/docs-new/rest/margin-trading/debit/modify-leverage}{KuCoin Modify Leverage}

Verified: 2026-05-23
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl --location --request POST 'https://api.kucoin.com/api/v3/position/update-user-leverage' \\
  --header 'Content-Type: application/json' \\
  --header 'KC-API-KEY: your-api-key' \\
  --header 'KC-API-SIGN: your-signature' \\
  --header 'KC-API-TIMESTAMP: 1729176273859' \\
  --header 'KC-API-PASSPHRASE: your-passphrase' \\
  --header 'KC-API-KEY-VERSION: 2' \\
  --data-raw '\{"leverage":"5"\}'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "leverage": "5"
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "code": "200000",
  "data": null
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{KucoinMarginTrading$modify_leverage(leverage)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{leverage}}{(scalar<numeric>) the desired leverage multiplier (e.g.,
\code{3}, \code{5}, \code{10}).}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) one row giving the new leverage
multiplier and a \code{"success"} status.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
margin <- KucoinMarginTrading$new()
margin$modify_leverage(leverage = 5)
}
}
\if{html}{\out{</div>}}

}

}
